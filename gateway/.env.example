# Guaicaramo Control — Gateway config (copiar a .env y rellenar)

# Airtable
AIRTABLE_API_TOKEN=patXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_PLACAS_TABLE=Placas
AIRTABLE_REGISTROS_TABLE=Registros
AIRTABLE_TIMEOUT=15

# Conexión al nodo Meshtastic. Definir SOLO UNA de las tres:
#   MESHTASTIC_SERIAL : path serial (ej: /dev/ttyUSB0, /dev/cu.SLAB_USBtoUART)
#   MESHTASTIC_TCP    : hostname/IP del nodo en modo TCP/MQTT bridge
#   MESHTASTIC_BLE    : MAC address del nodo (sólo Linux con bluetoothctl OK)
MESHTASTIC_SERIAL=/dev/ttyUSB0
# MESHTASTIC_TCP=192.168.1.50
# MESHTASTIC_BLE=AA:BB:CC:DD:EE:FF
